# =========================================================================
# CareerOS — environment variables
# Copy to `.env` and fill in real values. Never commit real secrets.
# =========================================================================

# ---- Supabase (public — safe to expose in the client bundle) ------------
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOi..."
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT"

# ---- Supabase (server) --------------------------------------------------
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="eyJhbGciOi..."
SUPABASE_PROJECT_ID="YOUR_PROJECT"
# Service role — server-only. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=""

# ---- AI provider (Google Gemini) ----------------------------------------
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
# Optional overrides
GEMINI_MODEL="gemini-2.0-flash"

# ---- Runtime ------------------------------------------------------------
NODE_ENV="production"
PORT="8080"
HOST="0.0.0.0"
